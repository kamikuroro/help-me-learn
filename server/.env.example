# Server
PORT=3741
HOST=0.0.0.0

# db9.ai PostgreSQL connection
# Get this from: db9 create --name help-me-learn
DB9_CONNECTION_STRING=postgres://user:pass@pg.db9.io:5433/help-me-learn?sslmode=require

# Authentication (generate with: openssl rand -hex 32)
API_TOKEN=your-secret-token-here

# Jina Reader (optional, increases rate limit from 20 to 500 RPM)
# Get from: https://jina.ai/reader
JINA_API_KEY=

# TTS provider: elevenlabs | fishaudio | qwen3tts | kokoro
TTS_PROVIDER=elevenlabs

# ElevenLabs TTS
# Get from: https://elevenlabs.io/settings/api-keys
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Fish Audio TTS
FISH_AUDIO_API_KEY=

# Qwen3-TTS (local, free — requires running Qwen3-TTS-Openai-Fastapi server)
# See: https://github.com/bigsk1/Qwen3-TTS-Openai-Fastapi
QWEN3_TTS_BASE_URL=http://localhost:8880
QWEN3_TTS_VOICE_EN=demo_speaker0
QWEN3_TTS_VOICE_ZH=demo_speaker0

# Kokoro TTS (local, free, lightweight — via mlx-audio for Apple Silicon GPU)
# Setup: pip install "mlx-audio[server]" "misaki[en,zh]" soundfile
# Start: mlx_audio.server --host 0.0.0.0 --port 8880
# Model is auto-loaded on server startup.
KOKORO_TTS_BASE_URL=http://localhost:8880
KOKORO_TTS_MODEL=mlx-community/Kokoro-82M-bf16
KOKORO_TTS_VOICE_EN=af_heart
KOKORO_TTS_VOICE_ZH=zf_xiaobei

# Kokoro podcast voices (used for book-to-podcast feature)
KOKORO_PODCAST_HOST_A_EN=af_bella
KOKORO_PODCAST_HOST_A_ZH=zf_xiaoyi
KOKORO_PODCAST_HOST_B_EN=am_adam
KOKORO_PODCAST_HOST_B_ZH=zm_yunxi
KOKORO_NARRATOR_EN=af_bella
KOKORO_NARRATOR_ZH=zf_xiaoyi

# Marker API (on-prem PDF-to-markdown extraction)
# See: https://github.com/datalab-to/marker
MARKER_API_BASE_URL=http://localhost:8001
MARKER_TIMEOUT_MS=300000

# Claude CLI
CLAUDE_PATH=claude
CLAUDE_MODEL=opus
CLAUDE_TIMEOUT_MS=1200000

# Audio storage (local path for generated audio files)
AUDIO_DIR=../audio

# Logging
LOG_LEVEL=info
