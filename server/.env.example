# Server
PORT=3741
HOST=0.0.0.0

# db9.ai PostgreSQL connection
# Get this from: db9 create --name help-me-learn
DB9_CONNECTION_STRING=postgres://user:pass@pg.db9.io:5433/help-me-learn?sslmode=require

# Authentication (generate with: openssl rand -hex 32)
API_TOKEN=your-secret-token-here

# Jina Reader (optional, increases rate limit from 20 to 500 RPM)
# Get from: https://jina.ai/reader
JINA_API_KEY=

# TTS provider: elevenlabs | fishaudio | qwen3tts | kokoro
TTS_PROVIDER=elevenlabs

# ElevenLabs TTS
# Get from: https://elevenlabs.io/settings/api-keys
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Fish Audio TTS
FISH_AUDIO_API_KEY=

# Qwen3-TTS (local, free — requires running Qwen3-TTS-Openai-Fastapi server)
# See: https://github.com/bigsk1/Qwen3-TTS-Openai-Fastapi
QWEN3_TTS_BASE_URL=http://localhost:8880
QWEN3_TTS_VOICE_EN=demo_speaker0
QWEN3_TTS_VOICE_ZH=demo_speaker0

# Kokoro TTS (local, free, lightweight — requires Kokoro-FastAPI server)
# docker run -p 8880:8880 ghcr.io/remsky/kokoro-fastapi-cpu:latest
KOKORO_TTS_BASE_URL=http://localhost:8880
KOKORO_TTS_VOICE_EN=af_heart
KOKORO_TTS_VOICE_ZH=zf_xiaobei

# Claude CLI
CLAUDE_PATH=claude
CLAUDE_MODEL=opus
CLAUDE_TIMEOUT_MS=1200000

# Audio storage (local path for generated audio files)
AUDIO_DIR=../audio

# Logging
LOG_LEVEL=info
